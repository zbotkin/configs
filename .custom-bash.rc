## this crashes my tmux window so figure out wtf is going on here
function replace-aws-creds-in-env() {

	CREDS_FILE="$HOME/.aws/credentials"
	TARGET_FILE="$1"

	if [ -z "$TARGET_FILE" ]; then
  	echo "Usage: $0 <file_to_update>"
  	exit 1
	fi

	# Loop over each line in the creds file
	while IFS='=' read -r key value; do
    	# skip empty lines or comments
    	[[ -z "$key" || "$key" =~ ^# ]] && continue

    	# Trim whitespace
    	key=$(echo "$key" | xargs)
    	value=$(echo "$value" | xargs)

			upper_key=${key^^}

    	# If line already exists in target, replace it; otherwise, append it
    	if grep -q "^export $upper_key=" "$TARGET_FILE"; then
        	sed -i "s|^export $upper_key=.*|export $upper_key=$value|" "$TARGET_FILE"
    	else
        	echo "export $upper_key=$value" >> "$TARGET_FILE"
    	fi
	done < "$CREDS_FILE"

	echo "Updated $TARGET_FILE with values from $CREDS_FILE"

}

