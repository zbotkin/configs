function find-replace() {
  if [[ -z $1 ]]
  then
    echo "Need a find"
  elif [[ -z $2 ]]
  then
    echo "Need a replace"
  else
    grep -RiIl "$1" | xargs sed -i "s/$1/$2/g"
  fi
}

function mono-repo() {

  REPO_NAME=""
  BUG_OR_FEATURE="f"
  BRANCH_DESC=""
  TICKET_NUMBER=""
  MASTER="no"
  while [[ $1 != "" ]]
  do
    case $1 in
      -r | --repo | --repo-name)
      REPO_NAME="$2"
      shift
      shift
      ;;
      -b | --bug)
      BUG_OR_FEATURE="b"
      shift
      ;;
      -f | --feature)
      BUG_OR_FEATURE="f"
      shift
      ;;
      -d | --description | --desc)
      BRANCH_DESC="$2"
      shift
      shift
      ;;
      -t | --ticket | --jira)
      TICKET_NUMBER="$2"
      shift
      shift
      ;;
      -m | --master)
      MASTER="yes"
      shift
      ;;
      *)
      shift
      ;;
    esac
  done

  if [[ -z "$REPO_NAME" ]]
  then
    echo "need something to call this repo (-r or --repo or --repo-name)"
  elif [[ $MASTER == "no" && -z "$TICKET_NUMBER" ]]
  then
    echo "need a ticket/jira number (-t or --ticket or --jira)"
  else
    cd $PROJECTS_DIR
    git clone "$MONOREPO_LINK" "$REPO_NAME"
    cd "$REPO_NAME"
    if [[ -z "$BRANCH_DESC" ]]
    then
      BRANCH_DESC="$REPO_NAME"
    fi
    if [[ $MASTER != "yes" ]]
    then
      git checkout -b "$BUG_OR_FEATURE/CO$TICKET_NUMBER/$BRANCH_DESC"
    fi
  fi
}

