## I think if you are using tcs-runner since everything depends on log4j2ruby inside the Common.rb folder if you edit lib/log4j2ruby/log4j2.xml just set the root level to OFF and the appenderref level to OFF i think
## haven't tried it though
## or set the level to error to only log errors and higher
## on the AppenderRef in there
SSH_ENV="$HOME/.ssh/agent-environment"

function start_agent {
    echo "Initialising new SSH agent..."
    /usr/bin/ssh-agent | sed 's/^echo/#echo/' > "${SSH_ENV}"
    echo succeeded
    chmod 600 "${SSH_ENV}"
    . "${SSH_ENV}" > /dev/null
    /usr/bin/ssh-add;
}

