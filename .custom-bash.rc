function source-all-envs() {
  if [[ -z "$1" ]]
  then
    source-all-envs-dev
  elif [[ "$1" == "dev" ]]
  then
    source-all-envs-dev
  elif [[ "$1" == "test" || "$1" == "tst" ]]
  then
    source-all-envs-tst
  elif [[ "$1" == "nr" || "$1" == "nrl" ]]
  then
    source-all-envs-nrl
  else
    echo "$1" env not found
  fi
}
function unsource-all-envs() {
  if [[ -z "$1" ]]
  then
    unsource-all-envs-dev
  elif [[ "$1" == "dev" ]]
  then
    unsource-all-envs-dev
  elif [[ "$1" == "test" || "$1" == "tst" ]]
  then
    unsource-all-envs-tst
  elif [[ "$1" == "nr" || "$1" == "nrl" ]]
  then
    unsource-all-envs-nrl
  else
    echo "$1" env not found
  fi
}

