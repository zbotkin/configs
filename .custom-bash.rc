function set-px-engine() {
  REPO=""
  while [[ $1 != "" ]]
  do
    case $1 in
      -r | --repo)
      REPO="$2"
      shift
      shift
      ;;
    esac
  done
  FULL_DIR="$PROJECTS_DIR/$REPO"
  if [[ -d $FULL_DIR ]]
  then
    export PX_ENGINE_HOME="$FULL_DIR/Dockerfiles/asdf-builder"
    echo "PX_ENGINE_HOME: $PX_ENGINE_HOME"
  else
    echo "directory $FULL_DIR does not exist"
  fi
}

